<!DOCTYPE html>
<html>
<head>
    <title>My First Blog - Hello World</title>
    <style>
        /* This is the secret fix! It keeps the boxes from getting too wide */
        * {
            box-sizing: border-box;
        }

        body {
            background-color: #FFB6C1; /* Bright Light Pink */
            font-family: 'Arial', sans-serif;
            margin: 20px;
        }

        .nav-links {
            background-color: white;
            padding: 15px;
            border: 2px solid black;
            margin-bottom: 20px;
            text-align: center;
        }

        .main-post {
            background-color: white;
            padding: 20px;
            border: 2px solid black;
            margin-bottom: 20px;
        }

        /* Container for the boxes */
        .wrapper {
            width: 100%;
            overflow: auto; /* Cleans up the floats automatically */
        }

        .list-box {
            background-image: url('https://images.unsplash.com/photo-1517694712202-14dd9538aa97?ixlib=rb-1.2.1&auto=format&fit=crop&w=500&q=60');
            background-size: cover;
            background-position: center;
            border: 5px solid black;
            padding: 20px;
            
            /* The Layout Fixes */
            float: left; 
            width: 48%;    /* Nearly half the screen */
            margin: 1%;    /* Small gap in the middle */
            
            /* Text Styling (No white overlay) */
            color: white;
            text-shadow: 2px 2px 10px black, -2px -2px 10px black; 
            min-height: 250px;
        }

        /* Footer area */
        footer {
            clear: both;
            padding-top: 20px;
        }
    </style>
</head>
<body>

    <div class="nav-links">
        <a href="index.html">Home</a> | 
